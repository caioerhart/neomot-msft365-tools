# Azure AD (Entra ID) – App Registration
# Microsoft Graph → Application → Sites.ReadWrite.All
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value

# SharePoint site/library
SHAREPOINT_HOSTNAME=neomotelevadores.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/ArquivosNeomot
SHAREPOINT_LIBRARY_NAME=Documentos

# Caminho da pasta de origem (dentro da biblioteca)
SOURCE_FOLDER_PATH=INDUSTRIAL/ENGENHARIA MECANICA/MODELOS - PEÇAS

# Pasta de destino (copia na raiz desta pasta)
DEST_PARENT_FOLDER_PATH=INDUSTRIAL/PRODUCAO/BIBLIOTECA DESENHOS

# Subpasta opcional dentro do destino. Deixe vazio para copiar direto na raiz.
DEST_SYNC_FOLDER_NAME=

# Regras de filtro
DAYS_BACK=7
FILE_EXTENSIONS=.pdf,.dxf
RECURSIVE=true

# Se true, remove arquivo de mesmo nome no destino antes de copiar
REPLACE_IF_EXISTS=true
